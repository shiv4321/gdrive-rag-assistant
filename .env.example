# ─── Google Drive ──────────────────────────────────────────────
# Option 1: Service Account (recommended for production)
GOOGLE_SERVICE_ACCOUNT_JSON=        # Path to service-account.json OR inline JSON string

# Option 2: OAuth (for personal use)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/callback

# ─── Pinecone ──────────────────────────────────────────────────
PINECONE_API_KEY=
PINECONE_INDEX_NAME=drive-doc-index
PINECONE_HOST=

# ─── OpenAI ────────────────────────────────────────────────────
OPENAI_API_KEY=

# ─── App ───────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
CHUNK_SIZE=512
CHUNK_OVERLAP=64
TOP_K_RESULTS=5
